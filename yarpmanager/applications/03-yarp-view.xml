<?xml version="1.0" encoding="UTF-8"?>
<application>
  <name>YARP View</name>
  <description>Launch the RGB image viewer GUI.</description>
  <version>1.0</version>
  <authors>
    <author email="">Codex</author>
  </authors>
  <module>
    <name>bash</name>
    <parameters>-lc "./yarpmanager/bin/launch-yarpview.sh"</parameters>
    <node>localhost</node>
    <workdir>/workspace/project</workdir>
    <display>--visible_na</display>
    <ensure>
      <wait when="start">2.0</wait>
    </ensure>
  </module>
</application>
