<?xml version="1.0" encoding="UTF-8"?>
<application>
  <name>VFramer Right</name>
  <description>Launch the right event-camera viewer using the configured default source port.</description>
  <version>1.0</version>
  <authors>
    <author email="">Codex</author>
  </authors>
  <module>
    <name>vFramer</name>
    <parameters>--name /vframer/right --src /zynqGrabber/right/AE:o --width 640 --height 480</parameters>
    <node>localhost</node>
    <workdir>/workspace/project</workdir>
    <display>--visible_na</display>
    <ensure>
      <wait when="start">2.0</wait>
    </ensure>
  </module>
</application>
